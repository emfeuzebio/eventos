// src/composables/useRotas.js
import { ref, onMounted } from 'vue'
import api from '@/services/api'

export function useRotas(ativo = true) {
  const rotas = ref([])
  const loading = ref(false)
  const error = ref(null)

  const fetchRotas = async () => {
    loading.value = true
    error.value = null

    try {
      const res = await api.get('/rota', {
        params: ativo ? { ativo: 'SIM' } : {},
      })
      rotas.value = res.data
    } catch (err) {
      console.error('Erro ao carregar a lista de Rotas ativas:', err)
      error.value = err
    } finally {
      loading.value = false
    }
  }

  onMounted(fetchRotas)

  return {
    rotas,
    loading,
    error,
    fetchRotas, // caso queira recarregar manualmente
  }
}
